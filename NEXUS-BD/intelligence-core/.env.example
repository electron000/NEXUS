# ─── Server ───────────────────────────────────────────────────────────────────
PORT=8000
PRODUCTION=false

# ─── Security ─────────────────────────────────────────────────────────────────
INTERNAL_API_KEY=YOUR_SHARED_SECRET_KEY
NERVE_CENTER_ORIGIN=http://localhost:4000

# ─── LLM Providers (at least one recommended for full semantic scoring) ────────
OPENAI_API_KEY=
GEMINI_API_KEY=YOUR_GEMINI_API_KEY
GEMINI_MODEL_NAME="gemini-2.5-flash"

# ─── Feature Flags ────────────────────────────────────────────────────────────
USE_PYTRENDS=false
MODEL_PATH=models/
