# ─── Server ───────────────────────────────────────────────────────────────────
PORT=8000
PRODUCTION=false

# ─── Security ─────────────────────────────────────────────────────────────────
INTERNAL_API_KEY=CHANGE_ME_TO_A_SHARED_SECRET   # must match Nerve Center
NERVE_CENTER_ORIGIN=http://localhost:3001

# ─── LLM Providers (at least one recommended for full semantic scoring) ────────
OPENAI_API_KEY=
GEMINI_API_KEY=

# ─── Feature Flags ────────────────────────────────────────────────────────────
USE_PYTRENDS=true       # set false in CI or rate-limited environments
MODEL_PATH=models/      # directory where XGBoost model pickle is stored
