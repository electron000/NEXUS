# ─── Server ───────────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development
FRONTEND_ORIGIN=http://localhost:3000
LOG_LEVEL=info

# ─── Registrar APIs ───────────────────────────────────────────────────────────
GODADDY_KEY=YOUR_GODADDY_KEY
GODADDY_SECRET=YOUR_GODADDY_SECRET
PREFERRED_CURRENCY=INR
PORKBUN_KEY=YOUR_PORKBUN_KEY
PORKBUN_SECRET=YOUR_PORKBUN_SECRET
NAMECOM_USER=YOUR_NAMECOM_USER
NAMECOM_TOKEN=YOUR_NAMECOM_TOKEN

# ─── Database ─────────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=nexus
DB_USER=postgres
DB_PASSWORD=YOUR_DB_PASSWORD

# ─── Intelligence Core ────────────────────────────────────────────────────────
INTELLIGENCE_CORE_URL=http://localhost:8000
INTERNAL_API_KEY=YOUR_SHARED_SECRET_KEY
