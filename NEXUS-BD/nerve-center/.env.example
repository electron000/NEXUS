# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
FRONTEND_ORIGIN=http://localhost:3000
LOG_LEVEL=info

# ─── JWT ──────────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGE_ME_TO_A_LONG_RANDOM_SECRET
JWT_EXPIRES_IN=7d

# ─── PostgreSQL ───────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=nexus
DB_USER=postgres
DB_PASSWORD=postgres

# ─── Intelligence Core (FastAPI) ──────────────────────────────────────────────
INTELLIGENCE_CORE_URL=http://localhost:8000
INTERNAL_API_KEY=CHANGE_ME_TO_A_SHARED_SECRET
ML_TIMEOUT_MS=30000

# ─── Registrar APIs ───────────────────────────────────────────────────────────
# Namecheap (https://www.namecheap.com/support/api/intro/)
NAMECHEAP_API_USER=
NAMECHEAP_API_KEY=
NAMECHEAP_CLIENT_IP=

# GoDaddy (https://developer.godaddy.com/)
GODADDY_API_KEY=
GODADDY_API_SECRET=

# Porkbun (https://porkbun.com/api/json/v3/documentation)
PORKBUN_API_KEY=
PORKBUN_API_SECRET=

